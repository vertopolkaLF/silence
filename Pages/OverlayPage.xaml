<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="silence_.Pages.OverlayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24" Margin="24,24,24,24">
            <TextBlock x:Name="TitleTextBlock" x:Uid="OverlayPage.TitleText" Text="Overlay" FontSize="24" FontWeight="SemiBold"/>

            <StackPanel Spacing="8">
                <ToggleSwitch x:Name="OverlayEnabledToggle"
                              x:Uid="OverlayPage.OverlayEnabledToggle"
                              Header="Enable overlay"
                              OffContent="Overlay disabled"
                              OnContent="Overlay enabled"
                              Toggled="OverlayEnabledToggle_Toggled"/>
                <TextBlock x:Name="OverlayEnabledDescriptionTextBlock"
                           x:Uid="OverlayPage.OverlayEnabledDescriptionText"
                           Text="Shows mute status on top of all windows"
                           Opacity="0.6"
                           FontSize="12"/>
            </StackPanel>

            <StackPanel x:Name="VisibilityModePanel" Spacing="12">
                <TextBlock x:Name="VisibilityModeLabelText" x:Uid="OverlayPage.VisibilityModeLabel" Text="Visibility Mode" FontWeight="SemiBold" FontSize="14"/>
                <RadioButtons x:Name="VisibilityModeSelector" SelectionChanged="VisibilityModeSelector_SelectionChanged">
                    <RadioButton x:Name="VisibilityAlwaysItem" x:Uid="OverlayPage.VisibilityAlwaysItem" Content="Always visible" Tag="Always"/>
                    <RadioButton x:Name="VisibilityWhenMutedItem" x:Uid="OverlayPage.VisibilityWhenMutedItem" Content="Visible when muted" Tag="WhenMuted" IsChecked="True"/>
                    <RadioButton x:Name="VisibilityWhenUnmutedItem" x:Uid="OverlayPage.VisibilityWhenUnmutedItem" Content="Visible when unmuted" Tag="WhenUnmuted"/>
                    <RadioButton x:Name="VisibilityAfterToggleItem" x:Uid="OverlayPage.VisibilityAfterToggleItem" Content="Show after toggle" Tag="AfterToggle"/>
                </RadioButtons>

                <StackPanel x:Name="DurationPanel" Spacing="8" Visibility="Collapsed" Margin="0,8,0,0">
                    <TextBlock x:Name="DurationLabel" Text="Duration: 2.0s"/>
                    <Slider x:Name="DurationSlider"
                            Minimum="0.1"
                            Maximum="10"
                            StepFrequency="0.1"
                            TickFrequency="1"
                            TickPlacement="Outside"
                            Value="2"
                            ValueChanged="DurationSlider_ValueChanged"/>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="ScreenSelectionPanel" Spacing="12">
                <TextBlock x:Name="ScreenLabelText" x:Uid="OverlayPage.ScreenLabel" Text="Screen" FontWeight="SemiBold" FontSize="14"/>
                <ComboBox x:Name="ScreenComboBox"
                          x:Uid="OverlayPage.ScreenComboBox"
                          HorizontalAlignment="Stretch"
                          SelectionChanged="ScreenComboBox_SelectionChanged"
                          PlaceholderText="Select screen..."/>
                <TextBlock x:Name="ScreenDescriptionTextBlock"
                           x:Uid="OverlayPage.ScreenDescriptionText"
                           Text="Select which monitor to display the overlay on"
                           Opacity="0.6"
                           FontSize="12"/>
            </StackPanel>

            <StackPanel x:Name="PositionPanel" Spacing="12">
                <TextBlock x:Name="OverlayButtonModeLabelText"
                           Text="Use overlay as mute button"
                           FontWeight="SemiBold"
                           FontSize="14"/>
                <ToggleSwitch x:Name="OverlayButtonModeToggle"
                              x:Uid="OverlayPage.OverlayButtonModeToggle"
                              OffContent="Click-through overlay"
                              OnContent="Clickable mute toggle"
                              Toggled="OverlayButtonModeToggle_Toggled"/>
                <TextBlock x:Name="OverlayButtonModeDescriptionTextBlock"
                           x:Uid="OverlayPage.OverlayButtonModeDescriptionText"
                           Text="When enabled, the overlay stops being click-through, toggles the microphone on click, and can always be dragged."
                           Opacity="0.6"
                           FontSize="12"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="PositionTitleText"
                           Text="Overlay Position"
                           FontWeight="SemiBold"
                           FontSize="14"/>
                <TextBlock x:Name="CurrentPositionText"
                           Text="Current: Center, Bottom 20%"
                           Opacity="0.6"
                           FontSize="12"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="SetPositionButton"
                            x:Uid="OverlayPage.SetPositionButton"
                            Content="Set Position"
                            Click="SetPositionButton_Click"
                            HorizontalAlignment="Left"/>
                    <Button x:Name="DonePositionButton"
                            x:Uid="OverlayPage.DonePositionButton"
                            Content="Done"
                            Click="DonePositionButton_Click"
                            Visibility="Collapsed"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
                <TextBlock x:Name="PositionDescriptionTextBlock"
                           x:Uid="OverlayPage.PositionDescriptionText"
                           Text="Click to show overlay and drag it to desired position. The overlay will snap to center when close to the middle of the screen. Press ESC or click Done to save."
                           Opacity="0.6"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock x:Name="PreviewLabelText" x:Uid="OverlayPage.PreviewLabel" Text="Preview" FontWeight="SemiBold" FontSize="14"/>
                <Button x:Name="PreviewOverlayButton"
                        x:Uid="OverlayPage.PreviewOverlayButton"
                        Content="Preview Overlay"
                        Click="PreviewOverlayButton_Click"
                        HorizontalAlignment="Left"/>
            </StackPanel>

            <StackPanel x:Name="AppearancePanel" Spacing="12">
                <TextBlock x:Name="AppearanceTitleText" x:Uid="OverlayPage.AppearanceTitle" Text="Appearance" FontWeight="SemiBold" FontSize="24"/>

                <StackPanel Spacing="12" Margin="0,12,0,0">
                    <TextBlock x:Name="OverlayStyleLabelText" x:Uid="OverlayPage.OverlayStyleLabel" Text="Overlay Style" FontWeight="SemiBold" FontSize="14"/>
                    <Grid ColumnSpacing="12" ColumnDefinitions="52, 52, 52, 52, 52">
                        <Button x:Name="MicIconVariantButton"
                                Grid.Column="0"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="8"
                                Click="VariantButton_Click"
                                Tag="MicIcon">
                            <Button.Resources>
                                <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
                            </Button.Resources>
                            <StackPanel Spacing="4">
                                <Border x:Name="MicIconVariantBorder"
                                        Width="52" Height="52"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <Border Width="40" Height="40"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            CornerRadius="6"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE720;" FontSize="20" Foreground="#28A745"/>
                                    </Border>
                                </Border>
                                <TextBlock x:Name="MicIconVariantLabelText"
                                           x:Uid="OverlayPage.MicIconVariantLabel"
                                           Text="Mic Icon"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           Opacity="0.8"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="DotVariantButton"
                                Grid.Column="1"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="8"
                                Click="VariantButton_Click"
                                Tag="Dot">
                            <Button.Resources>
                                <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
                            </Button.Resources>
                            <StackPanel Spacing="4">
                                <Border x:Name="DotVariantBorder"
                                        Width="52" Height="52"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <Ellipse Width="20" Height="20"
                                             Fill="#28A745"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="DotVariantLabelText"
                                           x:Uid="OverlayPage.DotVariantLabel"
                                           Text="Dot"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           Opacity="0.8"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="8" Margin="0,12,0,0">
                    <TextBlock x:Name="ScaleLabel" Text="Size scale: 100%"/>
                    <Slider x:Name="ScaleSlider"
                            Minimum="10"
                            Maximum="400"
                            StepFrequency="5"
                            TickFrequency="25"
                            TickPlacement="Outside"
                            Value="100"
                            ValueChanged="ScaleSlider_ValueChanged"/>
                </StackPanel>

                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <TextBlock x:Name="ContentOpacityLabel" Text="Opacity: 100%"/>
                    <Slider x:Name="ContentOpacitySlider"
                            Minimum="20"
                            Maximum="100"
                            StepFrequency="5"
                            TickFrequency="10"
                            TickPlacement="Outside"
                            Value="100"
                            ValueChanged="ContentOpacitySlider_ValueChanged"/>
                </StackPanel>

                <StackPanel x:Name="MicIconSettingsPanel" Spacing="12" Margin="0,12,0,0">
                    <ToggleSwitch x:Name="ShowTextToggle"
                                  x:Uid="OverlayPage.ShowTextToggle"
                                  Header="Show text"
                                  OffContent="Icon only"
                                  OnContent="Icon with text"
                                  Toggled="ShowTextToggle_Toggled"/>

                    <TextBlock x:Name="IconStyleLabelText" x:Uid="OverlayPage.IconStyleLabel" Text="Icon style" Margin="0,8,0,0"/>
                    <ComboBox x:Name="IconStyleComboBox"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="IconStyleComboBox_SelectionChanged">
                        <ComboBoxItem x:Name="IconStyleColoredItem" x:Uid="OverlayPage.IconStyleColoredItem" Content="Colored (red/green)" Tag="Colored"/>
                        <ComboBoxItem x:Name="IconStyleMonochromeItem" x:Uid="OverlayPage.IconStyleMonochromeItem" Content="Monochrome" Tag="Monochrome"/>
                    </ComboBox>

                    <TextBlock x:Name="BackgroundStyleLabelText" x:Uid="OverlayPage.BackgroundStyleLabel" Text="Background" Margin="0,8,0,0"/>
                    <ComboBox x:Name="BackgroundStyleComboBox"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="BackgroundStyleComboBox_SelectionChanged">
                        <ComboBoxItem x:Name="BackgroundDarkItem" x:Uid="OverlayPage.BackgroundDarkItem" Content="Dark" Tag="Dark"/>
                        <ComboBoxItem x:Name="BackgroundLightItem" x:Uid="OverlayPage.BackgroundLightItem" Content="Light" Tag="Light"/>
                    </ComboBox>

                    <StackPanel Spacing="8" Margin="0,12,0,0">
                        <TextBlock x:Name="OpacityLabel" Text="Background opacity: 90%"/>
                        <Slider x:Name="OpacitySlider"
                                Minimum="0"
                                Maximum="100"
                                StepFrequency="5"
                                TickFrequency="10"
                                TickPlacement="Outside"
                                Value="90"
                                ValueChanged="OpacitySlider_ValueChanged"/>
                    </StackPanel>

                    <StackPanel Spacing="8" Margin="0,8,0,0">
                        <TextBlock x:Name="BorderRadiusLabel" Text="Border radius: 6px"/>
                        <Slider x:Name="BorderRadiusSlider"
                                Minimum="0"
                                Maximum="24"
                                StepFrequency="1"
                                TickFrequency="4"
                                TickPlacement="Outside"
                                Value="6"
                                ValueChanged="BorderRadiusSlider_ValueChanged"/>
                    </StackPanel>

                    <ToggleSwitch x:Name="ShowBorderToggle"
                                  x:Uid="OverlayPage.ShowBorderToggle"
                                  Header="Overlay border"
                                  OffContent="No border"
                                  OnContent="Show border"
                                  Margin="0,8,0,0"
                                  Toggled="ShowBorderToggle_Toggled"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
